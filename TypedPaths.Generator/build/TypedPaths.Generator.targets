<Project>

    <ItemGroup>
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="TypedPathsRoot" />
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="TypedPathsClassName" />
        <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="TypedPathsProjectDir" />
    </ItemGroup>

    <Target Name="_InjectTypedPathsAdditionalFiles"
            BeforeTargets="GenerateMSBuildEditorConfigFileCore;CoreCompile"
            Condition="'@(TypedPathsFolder)' != ''">
        <!-- Use absolute path so the **\* glob expands on all platforms (relative globs can be passed unexpanded to CSC on Windows) -->
        <ItemGroup>
            <_TypedPathsRootDir Include="$(MSBuildProjectDirectory)\%(TypedPathsFolder.Identity)" Condition="'%(TypedPathsFolder.Identity)' != ''">
                <ClassName>%(TypedPathsFolder.ClassName)</ClassName>
            </_TypedPathsRootDir>
        </ItemGroup>
        <ItemGroup>
            <AdditionalFiles Include="%(_TypedPathsRootDir.FullPath)\**\*">
                <TypedPathsRoot>%(_TypedPathsRootDir.FullPath)</TypedPathsRoot>
                <TypedPathsClassName>%(_TypedPathsRootDir.ClassName)</TypedPathsClassName>
                <TypedPathsProjectDir>$(MSBuildProjectDirectory)</TypedPathsProjectDir>
            </AdditionalFiles>
            <UpToDateCheckInput Include="%(_TypedPathsRootDir.FullPath)\**\*" />
        </ItemGroup>
    </Target>

</Project>